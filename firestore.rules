service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to get the user's role from their document (safely)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Function to check if user is an admin or director or principal
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        getUserData().role == 'dir' ||
        getUserData().role == 'princi' ||
        getUserData().role == 'hod'
      );
    }

    function isStaff() {
       return isAuthenticated() && (
        getUserData().role == 'staff' || 
        getUserData().role == 'princi'
      );
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can only read their own profile, Admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // ONLY admins can create or update users (prevents role escalation)
      allow write: if isAdmin();
    }

    // Rules for the 'leaves' collection
    match /leaves/{leaveId} {
      // Staff can read their own leaves, Admins can read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Staff can create leaves if:
      // 1. They are authenticated
      // 2. The UID matches their own
      // 3. The initial status is 'Pending' (Prevents auto-approving their own leave)
      allow create: if isAuthenticated() && (
        (request.resource.data.userId == request.auth.uid && request.resource.data.status == 'Pending') ||
        isAdmin()
      );
      
      // ONLY admins can update a leave entirely (for approving/rejecting)
      // Staff can update their own leave ONLY if:
      // 1. The leave is currently 'Pending'
      // 2. They are NOT trying to change the status
      // 3. They are NOT trying to change the userId
      allow update: if isAdmin() || (
        resource.data.userId == request.auth.uid && 
        resource.data.status == 'Pending' &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.userId == resource.data.userId
      );
      
      // Admins can delete if needed, staff can delete their own only if still Pending or Recommended
      allow delete: if isAdmin() || (
        resource.data.userId == request.auth.uid && 
        (resource.data.status == 'Pending' || resource.data.status == 'Recommended')
      );
    }

    // Rules for the 'compLeaveGrants' collection
    match /compLeaveGrants/{grantId} {
      // Staff can read their own grants; HODs and admins can read all
      allow read: if isAuthenticated() && (
        resource.data.staffId == request.auth.uid || isAdmin()
      );

      // Only HODs and admins can create comp leave grant records
      allow create: if isAuthenticated() && (
        getUserData().role == 'hod' ||
        getUserData().role == 'admin'
      );

      // No one can update or delete a grant once created (immutable audit trail)
      allow update, delete: if getUserData().role == 'admin';
    }

    // Rules for the 'vacationLeave' collection
    match /vacationLeave/{staffId} {
      // Staff can read their own vacation leave status; Admins/Directors can read all
      allow read: if isAuthenticated() && (staffId == request.auth.uid || isAdmin());
      
      // Only admins/directors can grant vacation leaves
      allow write: if isAdmin();
    }
  }
}
